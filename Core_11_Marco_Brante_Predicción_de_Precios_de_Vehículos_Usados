        "def evaluar_modelo(nombre, y_real, y_pred):\n",
        "    mse  = mean_squared_error(y_real, y_pred)\n",
        "    rmse = np.sqrt(mse)\n",
        "    r2   = r2_score(y_real, y_pred)\n",
        "\n",
        "    print(f'── {nombre} ──────────────────────────────')\n",
        "    print(f'  MSE  : ${mse:>15,.2f}')\n",
        "    print(f'  RMSE : ${rmse:>14,.2f}')\n",
        "    print(f'  R²   :  {r2:>14.4f}')\n",
        "    print()\n",
        "\n",
        "    return {'Modelo': nombre, 'MSE': mse, 'RMSE': rmse, 'R2': r2}"
      ]
