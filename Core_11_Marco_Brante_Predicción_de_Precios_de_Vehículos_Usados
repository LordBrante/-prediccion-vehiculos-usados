        "rf_base = RandomForestRegressor(random_state=seed, n_jobs=-1)\n",
        "\n",
        "grid_search = GridSearchCV(\n",
        "    estimator=rf_base,\n",
        "    param_grid=param_grid,\n",
        "    scoring='r2',\n",
